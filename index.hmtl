  <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:4px;color:var(--bronze);margin-bottom:14px;">✦ SCHRITT 2 — BETRIEB INFOS</p>
  <div class="form-grid">
    <div class="form-group"><label class="form-label">BETRIEBSNAME *</label><input class="form-input" id="f_betrieb" placeholder="z.B. Bäckerei Müller" type="text"></div>
    <div class="form-group"><label class="form-label">BRANCHE *</label><select class="form-select" id="f_branche"><option value="">Bitte wählen…</option><option>Restaurant / Café / Bar</option><option>Bäckerei / Konditorei</option><option>Friseur / Beauty / Kosmetik</option><option>Fitnessstudio / Sport</option><option>Modegeschäft / Boutique</option><option>Hotel / Pension</option><option>Handwerk / Baugewerbe</option><option>Arzt / Zahnarzt / Therapie</option><option>Immobilien</option><option>Einzelhandel</option><option>Dienstleistung</option><option>Andere</option></select></div>
    <div class="form-group"><label class="form-label">ANSPRECHPARTNER</label><input class="form-input" id="f_person" placeholder="z.B. Herr Müller" type="text"></div>
    <div class="form-group"><label class="form-label">INSTAGRAM-STATUS *</label><select class="form-select" id="f_insta"><option value="">Bitte wählen…</option><option>Kein Instagram-Account</option><option>Account vorhanden, aber kaum Aktivität</option><option>Postet gelegentlich, veraltete Inhalte</option><option>Aktiv, aber unprofessionell</option><option>Aktiv, aber wenig Follower</option></select></div>
    <div class="form-group"><label class="form-label">FOLLOWERZAHL</label><select class="form-select" id="f_follower"><option value="">Bitte wählen…</option><option>Kein Account</option><option>0–100</option><option>100–500</option><option>500–1000</option><option>1000–5000</option><option>5000+</option></select></div>
    <div class="form-group"><label class="form-label">ERWARTETER EINWAND</label><select class="form-select" id="f_einwand"><option value="">Bitte wählen…</option><option>„Kein Interesse"</option><option>„Zu teuer"</option><option>„Machen wir selbst"</option><option>„Keine Zeit"</option><option>Unbekannt</option></select></div>
    <div class="form-group full"><label class="form-label">BESONDERHEITEN (OPTIONAL)</label><textarea class="form-textarea" id="f_besonders" placeholder="z.B. Neueröffnung, bekannte Marke, Mitbewerber sehr aktiv…"></textarea></div>
  </div>

  <button class="btn btn-primary" onclick="openInClaude()" style="margin-bottom:8px;">✦ LEITFADEN MIT KI ERSTELLEN →</button>
  <p style="color:var(--text-muted);font-size:13px;font-style:italic;">↗ Öffnet Claude mit allen deinen Daten — kostenlos, keine Anmeldung nötig.</p>

  <div class="result-box" id="leitfadenResult">
    <div class="result-header"><span class="result-title" id="leitfadenTitle">LEITFADEN</span><button class="copy-btn" onclick="copyL()">KOPIEREN</button></div>
    <div class="result-body" id="leitfadenBody"></div>
  </div>
</div>
</div>

