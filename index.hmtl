<script>
var APIKEY='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';

async function callAI(messages,system,max_tokens){
  max_tokens=max_tokens||1000;
  var body={model:'claude-sonnet-4-6',max_tokens:max_tokens,messages:messages};
  if(system)body.system=system;
  try{
    var res=await fetch('/api',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(body)
    });
    var data=await res.json();
    if(data.error)throw new Error(data.error.message||'Fehler');
    return (data.content||[]).map(function(c){return c.text||'';}).join('');
  }catch(e){
    // Fallback: Claude direkt öffnen
    throw e;
  }
}

// ACCORDION
function toggleAcc(btn){
  var body=btn.nextElementSibling,arrow=btn.querySelector('.acc-arrow'),isOpen=body.classList.contains('open');
  document.querySelectorAll('.acc-body').forEach(function(b){b.classList.remove('open');});
  document.querySelectorAll('.acc-arrow').forEach(function(a){a.classList.remove('open');});
  if(!isOpen){body.classList.add('open');arrow.classList.add('open');}
}

// QUIZ - 15 Fragen
var questions=[
  {cat:"GESPRÄCHSABLAUF",q:"Was kommt direkt NACH der Begrüssung — bevor du den Grund des Anrufs nennst?",opts:["Direkt das Angebot erklären","Ein ehrliches, konkretes Lob über den Betrieb","Den Preis nennen","Fragen ob der Kunde Zeit hat"],correct:1,fb:"Richtig! Das Lob kommt immer vor dem Grund — es öffnet das Herz des Kunden."},
  {cat:"GESPRÄCHSABLAUF",q:"Was solltest du am Ende JEDES Gesprächs immer tun?",opts:["Den Preis nochmals nennen","Nach der E-Mail-Adresse fragen für den Fragebogen","Das Gespräch offen lassen","Sofort nochmal anrufen"],correct:1,fb:"Genau! Die E-Mail-Anfrage ist Pflicht — so bleibt die Türe immer offen."},
  {cat:"LOB",q:"Was macht ein gutes Lob am Telefon aus?",opts:["Es ist allgemein: 'Sie sind toll'","Es ist konkret und ehrlich — basierend auf echten Beobachtungen","Es ist lang und ausführlich","Es bezieht sich auf den Preis"],correct:1,fb:"Konkretes Lob wirkt echt. Allgemeines Lob klingt nach Trick."},
  {cat:"GESPRÄCHSABLAUF",q:"In welcher Reihenfolge läuft das Gespräch ab?",opts:["Angebot → Lob → Begrüssung","Begrüssung → Person bestätigen → Lob → Dienstleistung → E-Mail anfragen","Preis → Lob → Begrüssung","E-Mail → Begrüssung → Angebot"],correct:1,fb:"Perfekt! Diese Reihenfolge schafft Vertrauen Schritt für Schritt."},
  {cat:"EINWÄNDE",q:"Ein Kunde sagt: 'Wir machen Instagram selbst.' Was antwortest du?",opts:["'Dann brauchen Sie uns nicht'","'Das ist toll — wir ergänzen was Sie haben. Darf ich die E-Mail schicken?'","Den Preis senken","Gespräch beenden"],correct:1,fb:"Anerkenne die Eigenleistung und zeige Mehrwert — führe zur E-Mail-Anfrage."},
  {cat:"FRAGEBOGEN",q:"Was enthält der Fragebogen?",opts:["Nur den Preis","Wünsche, gewünschtes Angebot, Instagram-Zugangsdaten","Nur Kontaktinfos","Eine Rechnung"],correct:1,fb:"Richtig! Im Fragebogen trägt der Kunde alles ein — Zugangsdaten werden danach gelöscht."},
  {cat:"EINWÄNDE",q:"Ein Kunde hat Bedenken wegen seiner Passwörter. Was sagst du?",opts:["'Das ist Ihr Problem'","'Zugangsdaten werden nur für die Bearbeitung genutzt und danach sofort gelöscht.'","Preis senken","Thema wechseln"],correct:1,fb:"Transparenz schafft Vertrauen beim sensiblen Thema Zugangsdaten."},
  {cat:"EINWÄNDE",q:"Ein Kunde sagt: 'Keine Zeit für Instagram.' Wie reagierst du?",opts:["'Dann nichts für Sie'","'Genau deshalb gibt es uns — wir übernehmen alles. Sie füllen einmal den Fragebogen aus.'","Preis senken","Erklären wie viel Zeit es braucht"],correct:1,fb:"'Keine Zeit' ist der perfekte Übergang — du nimmst ihnen die Arbeit ab."},
  {cat:"KOMMUNIKATION",q:"Was bedeutet aktives Zuhören?",opts:["Schweigen bis der Kunde fertig ist","Notizen machen, Signale geben ('Ich verstehe'), ausreden lassen","E-Mails lesen","Unterbrechen"],correct:1,fb:"Aktives Zuhören zeigt Respekt und hilft den echten Bedarf zu verstehen."},
  {cat:"LOB",q:"Warum ist das Lob wichtig BEVOR du den Grund nennst?",opts:["Nicht wichtig","Es schafft Verbindung — der Kunde ist offener für alles danach","Macht Gespräch länger","Zeigt Höflichkeit"],correct:1,fb:"Wer sich wertgeschätzt fühlt, hört zu. Das Lob öffnet die Türe."},
  {cat:"GESPRÄCHSABLAUF",q:"Was sagst du wenn der Kunde Interesse zeigt?",opts:["Sofort den Preis nennen","'Danke! Wir haben verschiedene Angebote…' — Pakete kurz vorstellen","Gespräch beenden","Fragebogen vorlesen"],correct:1,fb:"Erst bedanken, dann Angebote kurz vorstellen — nicht überwältigen."},
  {cat:"FRAGEBOGEN",q:"Was passiert mit Instagram-Zugangsdaten nach der Bearbeitung?",opts:["Gespeichert","Sofort gelöscht — Kunde bekommt alles zurück","An Dritte","Bleiben im System"],correct:1,fb:"Zugangsdaten werden nach Bearbeitung sofort gelöscht. Das schafft Vertrauen."},
  {cat:"KOMMUNIKATION",q:"Wie oft den Namen benutzen?",opts:["Gar nicht","2–3 Mal — schafft Verbindung","Bei jedem Satz","Nur am Anfang"],correct:1,fb:"2–3 Mal ist ideal — persönlich ohne aufdringlich zu wirken."},
  {cat:"KOMMUNIKATION",q:"Warum ist Lächeln beim Telefonieren wichtig?",opts:["Nicht wichtig","Verändert die Stimme hörbar — Freundlichkeit überträgt sich","Macht Anruf schneller","Kunde sieht es"],correct:1,fb:"Die Stimme ist das einzige Werkzeug — Lächeln macht sie wärmer."},
  {cat:"INSTAGRAM",q:"Welches Argument überzeugt am ehesten?",opts:["'Alle machen es'","'Ihre Zielkunden suchen täglich auf Instagram nach Betrieben wie Ihrem'","'Instagram macht Spass'","'Es ist kostenlos'"],correct:1,fb:"Zielgruppen-Relevanz ist das stärkste Argument. Der Kunde sieht den direkten Nutzen."}
];

var cur=0,score=0,answered=false;
function renderQ(){
  var q=questions[cur];
  document.getElementById('quizProgress').textContent='FRAGE '+(cur+1)+' VON '+questions.length;
  document.getElementById('quizFill').style.width=(((cur+1)/questions.length)*100)+'%';
  document.getElementById('quizCat').textContent=q.cat;
  document.getElementById('quizQ').textContent=q.q;
  var opts=document.getElementById('quizOpts');opts.innerHTML='';
  q.opts.forEach(function(o,i){
    var btn=document.createElement('button');btn.className='quiz-opt';btn.textContent=o;
    btn.onclick=function(){answerQ(i,btn);};opts.appendChild(btn);
  });
  document.getElementById('quizFb').className='quiz-feedback';
  document.getElementById('quizFb').textContent='';
  document.getElementById('quizNext').className='quiz-next';
  answered=false;
}
function answerQ(i,btn){
  if(answered)return;answered=true;
  var q=questions[cur];
  document.querySelectorAll('.quiz-opt').forEach(function(b){b.disabled=true;});
  var fb=document.getElementById('quizFb');
  if(i===q.correct){btn.classList.add('correct');fb.textContent='✓ '+q.fb;fb.className='quiz-feedback show ok';score++;}
  else{btn.classList.add('wrong');document.querySelectorAll('.quiz-opt')[q.correct].classList.add('correct');fb.textContent='✗ '+q.fb;fb.className='quiz-feedback show nok';}
  document.getElementById('quizNext').className='quiz-next show';
}
function nextQ(){
  cur++;
  if(cur>=questions.length){
    document.getElementById('quizContent').style.display='none';
    document.getElementById('quizScore').className='quiz-score show';
    document.getElementById('scoreNum').textContent=score+' / '+questions.length;
    var p=score/questions.length;
    var msg=p<0.4?'Noch viel zu lernen!':p<0.6?'Guter Anfang!':p<0.8?'Solide Leistung!':p<1?'Sehr gut!':'Perfekt — bereit für jedes Gespräch!';
    document.getElementById('scoreMsg').textContent=msg;
  }else{renderQ();}
}
function restartQuiz(){cur=0;score=0;document.getElementById('quizContent').style.display='block';document.getElementById('quizScore').className='quiz-score';renderQ();}
renderQ();

// LOB GENERATOR
async function generateLob(){
  var info=document.getElementById('lob_input').value.trim();
  if(!info){alert('Bitte trage etwas Positives über den Betrieb ein.');return;}
  var btn=document.getElementById('lobBtn');
  btn.disabled=true;btn.textContent='KI erstellt Vorschläge…';
  document.getElementById('lobVariants').className='lob-variants';
  try{
    var text=await callAI([{role:'user',content:'Erstelle 3 verschiedene natürliche Lob-Sätze für ein Telefongespräch basierend auf: "'+info+'". Ehrlich, konkret, direkt nach der Vorstellung gesagt, Respekt für den Betrieb. Deutsch, max 2-3 Sätze. NUR JSON: [{"v":1,"t":"..."},{"v":2,"t":"..."},{"v":3,"t":"..."}]'}],null,600);
    var match=text.match(/\[[\s\S]*\]/);
    if(!match)throw new Error('kein json');
    var variants=JSON.parse(match[0]);
    var list=document.getElementById('lobList');list.innerHTML='';
    variants.forEach(function(v){
      var div=document.createElement('div');div.className='lob-variant';
      div.innerHTML='<div class="lob-variant-num">VARIANTE '+v.v+'</div>'+v.t;
      div.onclick=function(){
        document.querySelectorAll('.lob-variant').forEach(function(d){d.classList.remove('selected');});
        div.classList.add('selected');
        document.getElementById('lob_chosen').value=v.t;
      };
      list.appendChild(div);
    });
    document.getElementById('lobVariants').className='lob-variants show';
  }catch(e){
    // Fallback: Claude öffnen
    var prompt='Erstelle 3 natürliche Lob-Sätze für ein Telefongespräch basierend auf: "'+info+'". Ehrlich, konkret, Respekt für den Betrieb aussprechen. Auf Deutsch.';
    window.open('https://claude.ai/new?q='+encodeURIComponent(prompt),'_blank');
    alert('KI-Verbindung nicht möglich — Claude wurde in einem neuen Tab geöffnet!');
  }
  btn.disabled=false;btn.textContent='✦ LOB-SÄTZE GENERIEREN';
}

// LEITFADEN MIT CLAUDE
function openInClaude(){
  var betrieb=document.getElementById('f_betrieb').value.trim();
  var branche=document.getElementById('f_branche').value;
  var person=document.getElementById('f_person').value.trim()||'Unbekannt';
  var insta=document.getElementById('f_insta').value;
  var follower=document.getElementById('f_follower').value||'Unbekannt';
  var einwand=document.getElementById('f_einwand').value||'Unbekannt';
  var besonders=document.getElementById('f_besonders').value.trim()||'Keine';
  var lob=document.getElementById('lob_chosen').value.trim()||'Passenden Lob-Satz erstellen';
  if(!betrieb||!branche||!insta){alert('Bitte Betriebsname, Branche und Instagram-Status ausfüllen.');return;}
  var prompt='Erstelle einen vollständigen Telefon-Gesprächsleitfaden für NORIVO (wir verkaufen Instagram-Auffrischung: Fotos, Reels, Stories, Bio-Optimierung):\n\nBetrieb: '+betrieb+'\nBranche: '+branche+'\nAnsprechpartner: '+person+'\nInstagram-Status: '+insta+'\nFollower: '+follower+'\nErwarteter Einwand: '+einwand+'\nBesonderheiten: '+besonders+'\nLob-Satz: '+lob+'\n\nLeitfaden mit diesen Abschnitten (alle Sätze ausgeschrieben auf Deutsch):\n1. BEGRÜSSUNG\n2. PERSON BESTÄTIGEN\n3. LOB (Lob-Satz einbauen + Respekt)\n4. GRUND DES ANRUFS\n5. BEI INTERESSE\n6. EINWANDBEHANDLUNG\n7. E-MAIL ANFRAGEN\n8. FRAGEBOGEN ERKLÄREN\n9. VERABSCHIEDUNG';
  var url='https://claude.ai/new?q='+encodeURIComponent(prompt);
  var win=window.open(url,'_blank');
  document.getElementById('leitfadenResult').className='result-box show';
  document.getElementById('leitfadenTitle').textContent='CLAUDE GEÖFFNET';
  document.getElementById('leitfadenBody').innerHTML='<div style="color:#4caf82;margin-bottom:14px;">✓ Claude wurde in einem neuen Tab geöffnet mit allen Betriebsdaten!</div><a href="'+url+'" target="_blank" style="color:var(--bronze-light);font-size:16px;font-weight:bold;">→ Falls Claude nicht geöffnet wurde: Hier klicken</a>';
}
function copyL(){navigator.clipboard.writeText(document.getElementById('leitfadenBody').innerText).then(function(){var b=document.querySelector('.copy-btn');b.textContent='KOPIERT ✓';setTimeout(function(){b.textContent='KOPIEREN';},2000);});}

// KI CHAT
var chatHistory=[];
function openChatClaude(text){
  var system='Du bist NORIVO Telefon-Sales-Coach. NORIVO verkauft Instagram-Auffrischung. Gesprächsablauf: 1.Begrüssung 2.Person bestätigen 3.Lob VOR dem Grund 4.Dienstleistung 5.Angebote 6.E-Mail anfragen 7.Fragebogen erklären 8.Verabschiedung. Antworte auf Deutsch.';
  window.open('https://claude.ai/new?q='+encodeURIComponent(system+'\n\n'+text),'_blank');
}
function sendMsg(){
  var input=document.getElementById('chatInput');
  var text=input.value.trim();
  if(!text)return;
  input.value='';
  appendMsg(text,'user');
  openChatClaude(text);
  setTimeout(function(){
    appendMsg('Claude wurde in einem neuen Tab geöffnet mit deiner Frage! Falls kein Tab geöffnet wurde, prüfe ob Popups erlaubt sind.','ai',false);
  },300);
}
function appendMsg(text,role,isTyping){
  var box=document.getElementById('chatMessages');
  var wrap=document.createElement('div');wrap.className='msg msg-'+role;
  if(role==='ai'){var l=document.createElement('div');l.className='msg-ai-label';l.textContent='KI-TRAINER';wrap.appendChild(l);}
  var content=document.createElement('div');
  content.style.cssText=isTyping?'font-style:italic;color:#5a8a6a;':'color:#d0c0a0;';
  content.textContent=text;wrap.appendChild(content);box.appendChild(wrap);
  box.scrollTop=box.scrollHeight;return content;
}
</script>
</body>
</html>
