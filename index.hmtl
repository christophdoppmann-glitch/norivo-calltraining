    <div class="chat-header">
      <svg width="30" height="30" viewBox="0 0 70 70"><circle cx="35" cy="35" r="32" fill="none" stroke="#b8882a" stroke-width="1.5"/><rect x="20" y="17" width="7" height="36" fill="#b8882a"/><rect x="43" y="17" width="7" height="36" fill="#b8882a"/><polygon points="20,17 27,17 50,53 43,53" fill="#b8882a"/></svg>
